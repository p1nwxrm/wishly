# ==========================================
# BACKEND (FastAPI)
# ==========================================
# Virtual environments strictly for the backend
backend/.venv/
backend/venv/

# Backend secrets and environment variables
backend/.env
backend/.env.*
!backend/.env.example

# Python cache (global rule)
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
alembic/__pycache__/

# ==========================================
# FRONTEND (Flutter & Dart)
# ==========================================
# Flutter/Dart build files and cache
frontend/.dart_tool/
frontend/.flutter-plugins
frontend/.flutter-plugins-dependencies
frontend/.pub-cache/
frontend/.pub/
frontend/build/

# Android-specific local cache and secrets
frontend/android/.gradle/
frontend/android/local.properties
frontend/android/key.properties
frontend/android/app/src/main/res/values/secrets.xml

# iOS/macOS-specific local cache
frontend/ios/Pods/
frontend/ios/.symlinks/
frontend/ios/Flutter/.last_build_id
frontend/ios/Flutter/App.framework
frontend/ios/Flutter/Flutter.framework
frontend/ios/Flutter/Flutter.podspec
frontend/ios/Flutter/Generated.xcconfig
frontend/ios/Flutter/app.flx
frontend/ios/Flutter/app.zip
frontend/ios/Flutter/flutter_assets/
frontend/ios/Flutter/flutter_export_environment.sh
frontend/macos/Flutter/ephemeral/

# Windows/Linux-specific cache
frontend/windows/flutter/ephemeral/
frontend/linux/flutter/ephemeral/

# ==========================================
# GLOBAL IDE & OS SETTINGS
# ==========================================
.idea/
.vscode/
.DS_Store
Thumbs.db